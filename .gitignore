# Generated benchmark run outputs (metrics.jsonl / summary.md / env.json).
# The committed human report lives in experiments/results/ instead.
artifacts/
# Generated leaderboard resume ledgers (regenerated by benchmarks/leaderboard.py;
# the committed human report lives in experiments/results/). Never publish these.
benchmarks/results/leaderboard_*.jsonl
# Same for the grow_policy real-data gate ledgers
# (experiments/grow_policy_real_data.py).
benchmarks/results/grow_policy_real_data*.jsonl
# Per-seed prediction cache regenerated by experiments/ensemble_diversity.py;
# the committed human reports live in experiments/results/ instead.
